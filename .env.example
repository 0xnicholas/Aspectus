# ── Server ──
PORT=3100

# ── PostgreSQL ──
DATABASE_URL=postgresql://aspectus:aspectus_dev@localhost:5432/aspectus
DB_MAX_CONNECTIONS=50
DB_MIN_CONNECTIONS=10

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Logging ──
RUST_LOG=aspectus_server=info,tower_http=info

# ── Service Tokens (v0.2+) ──
# Consumer project tokens (pandaria, constell, tokencamp, heirloom, emerald).
# Each token is used by the corresponding project to call POST /introspect.
# SERVICE_TOKENS=pandaria=secret123,constell=secret456

# ── Admin Service Token (v0.9.1+) ──
# Required for management endpoints (/tenants, /users, /api-keys, ...).
# Must be a strong, rotated secret. The token is hashed with SHA-256 before storage.
# ASPECTUS_ADMIN_SERVICE_TOKEN=change-me-in-production

# ── JWT (v0.4+) ──
# Generate keys: ./scripts/generate-jwt-keys.sh
JWT_TTL_SECONDS=900
# JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----...
# JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----...

# ── Opaque Token (v0.4+) ──
OPAQUE_TOKEN_TTL_SECONDS=3600

# ── Email (v0.9.2+) ──
# Transport: "logging" (default, dev/test) or "smtp".
# ASPECTUS_EMAIL_TRANSPORT=logging
# ASPECTUS_SMTP_HOST=smtp.example.com
# ASPECTUS_SMTP_PORT=587
# ASPECTUS_SMTP_USERNAME=aspectus@example.com
# ASPECTUS_SMTP_PASSWORD=change-me
# ASPECTUS_EMAIL_FROM=Aspectus <noreply@aspectus.local>
