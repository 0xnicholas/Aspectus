# ── Server ──
PORT=3100

# ── PostgreSQL ──
DATABASE_URL=postgresql://aspectus:aspectus_dev@localhost:5432/aspectus
DB_MAX_CONNECTIONS=50
DB_MIN_CONNECTIONS=10

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Logging ──
RUST_LOG=aspectus_server=info,tower_http=info

# ── Service Tokens (v0.2+) ──
# Set per project: PROJECT=token
# SERVICE_TOKENS=pandaria=secret123,tavern=secret456

# ── JWT (v0.4+) ──
# Generate keys: ./scripts/generate-jwt-keys.sh
JWT_TTL_SECONDS=900
# JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----...
# JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----...

# ── Opaque Token (v0.4+) ──
OPAQUE_TOKEN_TTL_SECONDS=3600
