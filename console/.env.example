# Console environment variables
# Copy to .env and fill in values
#
# SECURITY: VITE_SERVICE_TOKEN is baked into the client bundle.
# Only use this in development or internal-network deployments.
# For public-facing production, use a reverse proxy to inject the
# Authorization header (see console/src/api/client.ts for details).

VITE_API_BASE=http://localhost:3100
VITE_SERVICE_TOKEN=st_dev_your_service_token_here
